{
  "expo": {
    "name": "LOQE",
    "slug": "loqe-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "loqe",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": true
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f3f0ea"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.loqe.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.loqe.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f3f0ea"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "50222007-4529-4e0b-81d6-26f194f38d2f"
      }
    }
  }
}
